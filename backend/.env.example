# RealWorld backend — dev profile only (RFP §NFR-06 단일 환경 운영)
# Copy this file to backend/.env and fill in your local values.
# IMPORTANT: backend/.env is gitignored. Never commit real secrets.

# Database (SQLite + aiosqlite async driver). File at backend/data/realworld.db.
DATABASE_URL=sqlite+aiosqlite:///./data/realworld.db

# JWT signing — generate with: python -c "import secrets; print(secrets.token_urlsafe(32))"
# DO NOT use this placeholder value in any environment.
JWT_SECRET=changeme-please-generate-random-32-chars
JWT_ALG=HS256
JWT_EXPIRE_MINUTES=10080

# CORS — comma-separated origins. Vite dev server default port 5173.
CORS_ORIGINS=http://localhost:5173

# Logging
LOG_LEVEL=INFO
